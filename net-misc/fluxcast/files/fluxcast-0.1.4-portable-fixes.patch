+                    f"Icon={_ICON_PATH}\n"
+                    "Terminal=false\n"
+                    "X-GNOME-Autostart-enabled=true\n"
+                )
+            _notify("FluxCast", "FluxCast will now start automatically on login.")
+        except OSError as e:
