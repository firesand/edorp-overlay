+def _terminate_proc(proc: "subprocess.Popen") -> None:
+    """Stop a cast worker cleanly: TERM the whole process group, then escalate
+    to KILL if it doesn't exit — so a stuck session never blocks the next cast."""
+    if proc is None or proc.poll() is not None:
+        return
+    try:
+        pgid = os.getpgid(proc.pid)
+    except OSError:
+        pgid = None
+
+    def _signal(sig) -> None:
+        try:
+            if pgid is not None:
+                os.killpg(pgid, sig)
+            else:
+                proc.send_signal(sig)
+        except OSError:
+            pass
+
+    _signal(signal.SIGTERM)
+    try:
+        proc.wait(timeout=6)
+        return
+    except subprocess.TimeoutExpired:
+        pass
+    _log("worker ignored SIGTERM; escalating to SIGKILL")
+    _signal(signal.SIGKILL)
+    try:
+        proc.wait(timeout=3)
+    except subprocess.TimeoutExpired:
+        pass
+
+
