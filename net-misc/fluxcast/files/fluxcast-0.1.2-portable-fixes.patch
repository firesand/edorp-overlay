+                fp.write(
+                    "[Desktop Entry]\n"
+                    "Type=Application\n"
+                    "Name=FluxCast\n"
+                    "Comment=Stream your desktop to a Smart TV\n"
+                    "Exec=fluxcast --tray\n"
+                    f"Icon={_ICON_PATH}\n"
+                    "Terminal=false\n"
+                    "X-GNOME-Autostart-enabled=true\n"
+                )
+            _notify("FluxCast", "FluxCast will now start automatically on login.")
+        except OSError as e:
+            _log(f"autostart write failed: {e}")
+    _refresh()
+
+
