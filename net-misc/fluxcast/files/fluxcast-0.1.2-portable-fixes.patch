+def _toggle_autostart() -> None:
+    path = _autostart_file()
+    if _autostart_enabled():
+        try:
+            os.remove(path)
+            _notify("FluxCast", "Autostart on login disabled.")
+        except OSError as e:
+            _log(f"autostart remove failed: {e}")
+    else:
+        try:
