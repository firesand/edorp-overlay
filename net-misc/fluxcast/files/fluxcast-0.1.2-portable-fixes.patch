+# ── autostart on login ────────────────────────────────────────────────────────
+
+def _autostart_file() -> str:
+    base = os.environ.get("XDG_CONFIG_HOME") or os.path.expanduser("~/.config")
+    return os.path.join(base, "autostart", "fluxcast-tray.desktop")
+
