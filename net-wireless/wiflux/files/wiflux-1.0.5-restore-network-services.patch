+"""Regression tests for explicit ``--dict`` validation semantics."""
+
+from __future__ import annotations
+
+import io
+import json
+import os
+import tempfile
+import unittest
+from contextlib import redirect_stderr
+from pathlib import Path
+from unittest.mock import patch
+
+from wiflux.cli import args_to_config, build_parser
+
+
+class TestWordlistCLIValidation(unittest.TestCase):
+    def assert_dict_parse_error(self, value: str, expected: str) -> None:
+        stderr = io.StringIO()
+        with redirect_stderr(stderr):
+            with self.assertRaises(SystemExit) as raised:
+                build_parser().parse_args(["--dict", value])
+        self.assertEqual(raised.exception.code, 2)
+        self.assertIn("argument --dict", stderr.getvalue())
+        self.assertIn(expected, stderr.getvalue())
+
+    def test_missing_explicit_dict_fails_even_when_default_exists(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            default = Path(tmp, "default.txt")
+            default.write_text("password123\n", encoding="utf-8")
+            missing = str(Path(tmp, "missing.txt"))
+
+            with patch("wiflux.config.DEFAULT_WORDLISTS", [str(default)]):
+                self.assert_dict_parse_error(missing, "wordlist is not a file")
+
+    def test_empty_explicit_dict_fails(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            empty = Path(tmp, "empty.txt")
+            empty.touch()
+            self.assert_dict_parse_error(str(empty), "wordlist is empty")
+
+    def test_directory_explicit_dict_fails(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            self.assert_dict_parse_error(tmp, "wordlist is not a file")
+
+    def test_unreadable_explicit_dict_reports_argparse_error(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            wordlist = Path(tmp, "wordlist.txt")
+            wordlist.write_text("password123\n", encoding="utf-8")
+
+            error = PermissionError(13, "Permission denied", str(wordlist))
+            with patch.object(Path, "open", side_effect=error):
+                self.assert_dict_parse_error(str(wordlist), "wordlist is not readable")
+
+    def test_valid_relative_dict_is_resolved(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            wordlist = Path(tmp, "relative.txt")
+            wordlist.write_text("password123\n", encoding="utf-8")
+            previous_cwd = os.getcwd()
+            try:
+                os.chdir(tmp)
+                args = build_parser().parse_args(["--dict", "relative.txt"])
+            finally:
+                os.chdir(previous_cwd)
+
+            self.assertEqual(args.wordlist, str(wordlist.resolve()))
+
+    def test_explicit_valid_dict_overrides_config(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            root = Path(tmp)
+            configured = root / "configured.txt"
+            explicit = root / "explicit.txt"
+            configured.write_text("configured-password\n", encoding="utf-8")
+            explicit.write_text("explicit-password\n", encoding="utf-8")
+            config_file = root / "config.json"
+            config_file.write_text(
+                json.dumps(
+                    {
+                        "attack": {"wordlist": str(configured)},
+                        "output": {
+                            "data_dir": str(root / "data"),
+                            "handshake_dir": str(root / "handshakes"),
+                        },
+                    }
+                ),
+                encoding="utf-8",
+            )
+
+            args = build_parser().parse_args(
+                ["--config", str(config_file), "--dict", str(explicit)]
+            )
+            cfg = args_to_config(args)
+
+            self.assertEqual(cfg.attack.wordlist, str(explicit.resolve()))
+
+    def test_omitted_dict_preserves_default_fallback(self):
+        with tempfile.TemporaryDirectory() as tmp:
+            default = Path(tmp, "default.txt")
+            default.write_text("password123\n", encoding="utf-8")
+
+            with patch("wiflux.config.DEFAULT_WORDLISTS", [str(default)]):
+                cfg = args_to_config(build_parser().parse_args([]))
+
+            self.assertEqual(cfg.attack.wordlist, str(default))
+
+
+if __name__ == "__main__":
+    unittest.main()
