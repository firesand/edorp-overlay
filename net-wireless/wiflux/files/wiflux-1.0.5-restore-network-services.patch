+    def test_restore_is_idempotent(self) -> None:
+        commands: list[tuple[str, ...]] = []
+
+        def fake_run(command, **_kwargs):
+            commands.append(tuple(command))
+            if command[:2] == ["systemctl", "list-units"]:
+                return "NetworkManager.service loaded active running NM\n", "", 0
+            return "", "", 0
+
+        with (
+            patch("wiflux.tools.airmon.which", return_value=True),
+            patch("wiflux.tools.airmon.os.path.isdir", return_value=True),
+            patch("wiflux.tools.airmon.run", side_effect=fake_run),
+        ):
+            Airmon.kill_conflicts()
