+"""Regression tests for restoring services stopped by airmon-ng.
+
+Every service-manager, radio, and CLI interaction in this module is mocked.
+"""
+
+from __future__ import annotations
+
+import signal
+import unittest
+from types import SimpleNamespace
+from unittest.mock import MagicMock, patch
+
+from wiflux import cli
+from wiflux.tools.airmon import Airmon
+
+
+SYSTEMD_UNITS = """\
+wpa_supplicant.service loaded active running WPA supplicant
+wpa_supplicant@wlp9s0.service loaded active running WPA supplicant per interface
+NetworkManager.service loaded active running Network Manager
+ssh.service loaded active running OpenSSH daemon
+"""
+
+
+class ServiceSessionTestCase(unittest.TestCase):
+    def setUp(self) -> None:
+        Airmon.begin_session()
+
+    def tearDown(self) -> None:
+        Airmon.begin_session()
+
+    def test_systemd_snapshots_supported_active_units_and_templates(self) -> None:
+        commands: list[tuple[str, ...]] = []
+
+        def fake_run(command, **_kwargs):
+            commands.append(tuple(command))
+            if command[:2] == ["systemctl", "list-units"]:
+                return SYSTEMD_UNITS, "", 0
+            return "", "", 0
+
+        with (
+            patch("wiflux.tools.airmon.which", return_value=True),
+            patch("wiflux.tools.airmon.os.path.isdir", return_value=True),
+            patch("wiflux.tools.airmon.run", side_effect=fake_run),
+        ):
+            Airmon.kill_conflicts()
+            restored, failed = Airmon.restore_services()
+
+        self.assertEqual(failed, [])
+        self.assertEqual(
+            restored,
+            [
+                "wpa_supplicant.service",
+                "wpa_supplicant@wlp9s0.service",
+                "NetworkManager.service",
+            ],
+        )
+        self.assertNotIn("ssh.service", restored)
+        self.assertIn(
+            (
+                "systemctl", "list-units", "--type=service",
+                "--state=active", "--no-legend", "--plain",
+            ),
+            commands,
+        )
+
+    def test_restore_starts_wpa_before_networkmanager(self) -> None:
+        commands: list[tuple[str, ...]] = []
+
+        def fake_run(command, **_kwargs):
+            commands.append(tuple(command))
+            if command[:2] == ["systemctl", "list-units"]:
+                # Deliberately report NetworkManager first. Restore must still
+                # bring up the D-Bus supplicant backend before its consumer.
+                return (
+                    "NetworkManager.service loaded active running NM\n"
+                    "wpa_supplicant.service loaded active running WPA\n",
+                    "",
+                    0,
+                )
+            return "", "", 0
+
+        with (
+            patch("wiflux.tools.airmon.which", return_value=True),
+            patch("wiflux.tools.airmon.os.path.isdir", return_value=True),
+            patch("wiflux.tools.airmon.run", side_effect=fake_run),
+        ):
+            Airmon.kill_conflicts()
+            restored, failed = Airmon.restore_services()
+
+        self.assertEqual(
+            [command for command in commands if command[:2] == ("systemctl", "start")],
+            [
+                ("systemctl", "start", "wpa_supplicant.service"),
+                ("systemctl", "start", "NetworkManager.service"),
+            ],
+        )
+        self.assertEqual(restored, ["wpa_supplicant.service", "NetworkManager.service"])
+        self.assertEqual(failed, [])
+
+    def test_kill_is_idempotent_even_when_airmon_returns_nonzero(self) -> None:
+        commands: list[tuple[str, ...]] = []
+
+        def fake_run(command, **_kwargs):
+            commands.append(tuple(command))
+            if command[:2] == ["systemctl", "list-units"]:
+                return "NetworkManager.service loaded active running NM\n", "", 0
+            if command == ["airmon-ng", "check", "kill"]:
+                return "partially stopped processes", "failure", 1
+            return "", "", 0
+
+        with (
+            patch("wiflux.tools.airmon.which", return_value=True),
+            patch("wiflux.tools.airmon.os.path.isdir", return_value=True),
