+    @classmethod
+    def begin_session(cls) -> None:
+        """Reset per-process radio and service bookkeeping for a new CLI run."""
+        cls.base_interface = None
+        cls.base_device_path = None
+        cls._service_snapshot = []
+        cls._conflicts_killed = False
