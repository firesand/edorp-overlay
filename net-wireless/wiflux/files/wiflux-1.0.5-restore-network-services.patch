+def _install_termination_handlers() -> dict[int, object]:
+    """Turn service-manager termination signals into orderly CLI unwinds."""
+    previous: dict[int, object] = {}
+
+    def request_shutdown(signum, _frame) -> None:
+        raise SystemExit(128 + signum)
+
+    for name in ("SIGTERM", "SIGHUP"):
+        signum = getattr(signal, name, None)
+        if signum is None:
+            continue
+        previous[signum] = signal.getsignal(signum)
+        signal.signal(signum, request_shutdown)
+    return previous
+
+
+def _restore_termination_handlers(previous: dict[int, object]) -> None:
+    """Restore process signal handling after the radio cleanup is complete."""
+    for signum, handler in previous.items():
+        signal.signal(signum, handler)
+
+
+def _wordlist_arg(value: str) -> str:
+    """Validate an explicit --dict path before any privileged setup begins."""
+    if not value or not value.strip():
+        raise argparse.ArgumentTypeError("wordlist path cannot be empty")
+    path = Path(value).expanduser()
+    try:
+        if not path.is_file():
+            raise argparse.ArgumentTypeError(f"wordlist is not a file: {value}")
+        if path.stat().st_size <= 0:
+            raise argparse.ArgumentTypeError(f"wordlist is empty: {value}")
+        with path.open("rb") as handle:
+            handle.read(1)
+    except argparse.ArgumentTypeError:
+        raise
+    except OSError as exc:
+        raise argparse.ArgumentTypeError(
+            f"wordlist is not readable: {value} ({exc})",
+        ) from exc
+    return str(path.resolve())
+
