+    @classmethod
+    def kill_conflicts(cls, *, require_snapshot: bool = False) -> None:
+        """Run airmon-ng conflict cleanup once while preserving service state."""
+        if cls._conflicts_killed or not which("airmon-ng"):
+            return
+        services, snapshot_ok = cls._snapshot_active_services()
+        if require_snapshot and not snapshot_ok:
+            raise RuntimeError(
+                "Could not snapshot active network services; refusing "
+                "airmon-ng check kill because --restore was requested"
+            )
+        cls._service_snapshot = services
+        cls._conflicts_killed = True
+        run(["airmon-ng", "check", "kill"], timeout=15)
+
+    @classmethod
+    def restore_services(cls) -> tuple[list[str], list[str]]:
+        """Restart only services that were active before conflict cleanup."""
+        services = sorted(cls._service_snapshot, key=cls._restore_priority)
+        cls._service_snapshot = []
+        cls._conflicts_killed = False
+        restored: list[str] = []
+        failed: list[str] = []
+        for backend, service in services:
+            try:
+                if backend == "systemd":
+                    _, _, code = run(
