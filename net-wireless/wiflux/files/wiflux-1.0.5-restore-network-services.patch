+    @classmethod
+    def _snapshot_active_services(cls) -> tuple[list[tuple[str, str]], bool]:
+        """Return active network services and whether the snapshot succeeded."""
+        if which("systemctl") and os.path.isdir("/run/systemd/system"):
+            try:
+                stdout, _, code = run(
+                    [
+                        "systemctl", "list-units", "--type=service",
+                        "--state=active", "--no-legend", "--plain",
+                    ],
+                    timeout=10,
+                )
+            except OSError:
+                return [], False
+            if code == 0:
+                units = []
+                for line in stdout.splitlines():
+                    fields = line.split()
+                    if not fields:
+                        continue
+                    unit = fields[0]
+                    if (
+                        unit in cls._SYSTEMD_SERVICES
+                        or unit.startswith(cls._SYSTEMD_PREFIXES)
+                    ):
+                        units.append(("systemd", unit))
+                return units, True
+            # Do not silently treat a service-manager failure as an empty
+            # snapshot: that would make --kill --restore destructive.
+            return [], False
+
+        if which("rc-service"):
+            active = []
+            for service in cls._OPENRC_SERVICES:
+                try:
+                    _, _, code = run(
+                        ["rc-service", service, "status"], timeout=10,
+                    )
+                except OSError:
+                    return [], False
+                if code == 0:
+                    active.append(("openrc", service))
+            return active, True
+        return [], True
