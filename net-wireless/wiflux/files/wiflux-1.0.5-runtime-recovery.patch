+class TestWashCrashCircuitBreaker(unittest.TestCase):
+    def setUp(self):
+        Wash.reset_crash_state()
+
+    def tearDown(self):
+        Wash.reset_crash_state()
+
+    def test_sigsegv_disables_wash_without_spawning_it_again(self):
+        with (
+            patch.object(Wash, "available", return_value=True),
