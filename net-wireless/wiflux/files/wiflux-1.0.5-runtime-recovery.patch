+class TestWpsSessionCircuitBreaker(unittest.TestCase):
+    def test_crash_skips_remaining_wps_for_session_but_continues_handshake(self):
+        cfg = WifluxConfig()
+        cfg.scan.interface = "wlan0mon"
+        cfg.attack.pmkid = False
+        cfg.attack.handshake = True
+        tracker = ProgressTracker()
+        crash = ExternalToolCrash("reaver", -signal.SIGSEGV)
+
+        with tempfile.TemporaryDirectory() as data_dir:
+            orchestrator = Orchestrator(cfg, ResultStore(data_dir), tracker)
+            with (
+                patch.object(WPSPixieAttack, "run", side_effect=crash) as pixie,
+                patch.object(WPSPinAttack, "run") as pin,
+                patch.object(
+                    HandshakeAttack,
+                    "run",
+                    return_value=AttackResult(False, message="capture not found"),
+                ) as handshake,
+            ):
+                self.assertFalse(orchestrator._attack_one(_wps_ap()))
+                self.assertFalse(orchestrator._attack_one(_wps_ap()))
+
+        # The first fatal signal opens a session-level WPS circuit breaker.
+        pixie.assert_called_once()
+        pin.assert_not_called()
+        self.assertEqual(handshake.call_count, 2)
+        rendered_logs = "\n".join(tracker.logs)
+        self.assertIn("SIGSEGV", rendered_logs)
+        self.assertIn("wps", rendered_logs.lower())
+
+    def test_rich_markup_in_psk_is_rendered_safely_but_saved_raw(self):
+        cfg = WifluxConfig()
+        cfg.attack.offline_pixie = False
+        cfg.attack.pmkid = False
+        cfg.attack.handshake = False
+        tracker = ProgressTracker()
+        ap = _wps_ap()
+        raw_key = "lab[red]password"
+
+        with tempfile.TemporaryDirectory() as data_dir:
+            store = ResultStore(data_dir)
+            orchestrator = Orchestrator(cfg, store, tracker)
+            tracker.begin_attack(1, 1, ap)
+            with (
+                patch.object(
+                    WPSAttack,
+                    "run_pixie",
+                    return_value=(None, raw_key),
+                ),
+                patch.object(tracker, "clear_attack"),
+                patch("wiflux.orchestrator.print_crack"),
+            ):
+                self.assertTrue(orchestrator._attack_one(ap))
+
+            saved = store.list_cracks()
+            self.assertEqual(len(saved), 1)
+            self.assertEqual(saved[0].key, raw_key)
+
+            # Force Rich to parse every retained status/log entry.  A raw
+            # ``[red]`` tag here used to corrupt rendering before save_crack.
+            output = io.StringIO()
+            console = Console(
+                file=output,
+                force_terminal=False,
+                color_system=None,
+                width=120,
+            )
+            console.print(tracker.render())
+            self.assertIn(raw_key, output.getvalue())
+
