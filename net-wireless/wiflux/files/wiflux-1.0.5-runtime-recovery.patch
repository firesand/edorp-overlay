+            signum = -returncode
+            try:
+                status = f"crashed with {signal.Signals(signum).name} (signal {signum})"
+            except ValueError:
+                status = f"crashed with signal {signum}"
+        else:
+            status = f"crashed with exit {returncode}"
+        detail = f": {clean[-320:]}" if clean else ""
+        super().__init__(f"{tool} {status}{detail}")
