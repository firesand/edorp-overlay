+def sanitize_output(value: object) -> str:
+    """Strip terminal escape/control sequences from untrusted tool output."""
+    text = str(value or "")
+    text = _ANSI_OSC_RE.sub("", text)
+    text = _ANSI_CSI_RE.sub("", text)
+    return _CONTROL_RE.sub("", text)
+
