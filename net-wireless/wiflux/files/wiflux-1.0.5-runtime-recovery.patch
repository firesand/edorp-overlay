+from wiflux.process import ExternalToolCrash, ManagedProcess, sanitize_output
+from wiflux.tools.airodump import Airodump
+from wiflux.tools.interface import InterfaceRecoveryError
+
+
+class TestManagedProcessDiagnostics(unittest.TestCase):
+    def test_combined_output_tail_is_bounded_and_reports_exit(self):
+        marker = "WIFLUX-END-MARKER"
+        script = (
+            "import sys; "
+            "sys.stderr.write('x' * 1048576); "
+            f"sys.stdout.write('\\x1b[0m{marker}\\n'); "
+            "sys.stderr.flush(); sys.stdout.flush(); raise SystemExit(7)"
+        )
+        proc = ManagedProcess(
+            [sys.executable, "-c", script],
+            capture_output_tail=True,
+            output_tail_bytes=4096,
+        )
+        self.addCleanup(proc.kill)
+
+        self.assertEqual(proc.wait(timeout=5), 7)
+        tail = proc.output_tail()
+        self.assertLessEqual(len(tail.encode("utf-8")), 4096)
+        self.assertIn(marker, tail)
+
+        summary = proc.failure_summary()
+        self.assertIn("exit 7", summary)
+        self.assertIn(marker, summary)
+        self.assertNotIn("\x1b", summary)
+
+    @unittest.skipUnless(os.name == "posix", "POSIX signal return codes required")
+    def test_signal_exit_is_named_in_failure_summary(self):
+        script = "import os, signal; os.kill(os.getpid(), signal.SIGTERM)"
+        proc = ManagedProcess(
+            [sys.executable, "-c", script],
+            capture_output_tail=True,
+        )
+        self.addCleanup(proc.kill)
+
+        self.assertEqual(proc.wait(timeout=5), -signal.SIGTERM)
+        self.assertEqual(proc.failure_summary(), "signal 15 (SIGTERM)")
+
+    def test_sigsegv_summary_waits_for_natural_eof_tail(self):
+        proc = ManagedProcess.__new__(ManagedProcess)
+        proc.proc = Mock()
+        proc.proc.poll.return_value = -signal.SIGSEGV
+        proc._output_tail = bytearray(b"before-crash")
+        proc._output_lock = threading.Lock()
+        proc._output_thread = Mock()
+
+        def finish_eof(*, timeout):
+            self.assertEqual(timeout, 0.2)
+            with proc._output_lock:
+                proc._output_tail.extend(b"\nfinal-line-at-eof")
+
+        proc._output_thread.join.side_effect = finish_eof
+
+        summary = proc.failure_summary()
+
+        self.assertIn("signal 11 (SIGSEGV)", summary)
+        self.assertIn("final-line-at-eof", summary)
+        proc._output_thread.join.assert_called_once_with(timeout=0.2)
+
