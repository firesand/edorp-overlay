+            # The caller may continue scanning, but the crashed helper must stay
+            # disabled for this session instead of entering a crash loop.
+            self.assertEqual(Wash.scan_live("wlan0mon", timeout=10), {})
+
+        self.assertEqual(caught.exception.tool, "wash")
+        self.assertEqual(caught.exception.returncode, -signal.SIGSEGV)
