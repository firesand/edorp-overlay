+"""Regression coverage for state shared by infinite-mode scan cycles."""
+
+from __future__ import annotations
+
+import unittest
+from types import SimpleNamespace
+from unittest.mock import MagicMock, call, patch
+
+from wiflux import cli
+
+
+class InfiniteSessionStateTestCase(unittest.TestCase):
+    def test_main_reuses_one_orchestrator_across_two_scan_cycles(self) -> None:
+        cfg = SimpleNamespace(
+            infinite=True,
+            restore_managed=False,
+            output=SimpleNamespace(
+                quiet=True,
+                json_output=False,
+                data_dir="/mock/wiflux-data",
+            ),
+        )
+        tracker = object()
+        store = MagicMock(name="store")
+        store.start_session.return_value = 41
+
+        first_target = object()
+        second_target = object()
+        first_selected = [first_target]
+        second_selected = [second_target]
+
+        first_scanner = MagicMock(name="first_scanner")
+        first_scanner.scan.return_value = [first_target]
+        first_scanner.select_targets.return_value = first_selected
+
+        second_scanner = MagicMock(name="second_scanner")
+        second_scanner.scan.return_value = [second_target]
+        second_scanner.select_targets.return_value = second_selected
+
+        orchestrator = MagicMock(name="orchestrator")
+        orchestrator.attack_all.side_effect = [0, 1]
+
+        def config_from_args(args):
+            self.assertTrue(args.infinite)
+            self.assertTrue(args.quiet)
+            return cfg
+
+        # Raising on construction of the third Scanner stops the infinite loop
+        # only after both preceding scan/attack cycles completed successfully.
+        scanner_instances = [first_scanner, second_scanner, KeyboardInterrupt]
+
+        with (
+            patch("wiflux.cli.args_to_config", side_effect=config_from_args),
+            patch("wiflux.cli.run_commands", return_value=False),
+            patch("wiflux.cli.check_requirements"),
+            patch("wiflux.cli.reset_tracker", return_value=tracker),
+            patch("wiflux.cli.ResultStore", return_value=store) as store_cls,
+            patch("wiflux.cli.setup_interface", return_value="wlp9s0mon") as setup,
+            patch("wiflux.cli.Scanner", side_effect=scanner_instances) as scanner_cls,
+            patch("wiflux.cli.Orchestrator", return_value=orchestrator) as orch_cls,
+            patch("wiflux.cli.ProcessPool") as process_pool,
+            patch("wiflux.cli.print_info"),
+            patch("wiflux.cli.print_error"),
+            patch("wiflux.cli.Airmon.stop") as airmon_stop,
+        ):
+            result = cli.main(["--infinite", "--quiet"])
+
+        self.assertEqual(result, 0)
+        store_cls.assert_called_once_with("/mock/wiflux-data")
+        setup.assert_called_once_with(cfg)
+        store.start_session.assert_called_once_with("wlp9s0mon")
+
+        # The constructor must be outside the rescan loop. Runtime health and
+        # circuit-breaker state live on this single instance.
+        orch_cls.assert_called_once_with(cfg, store, tracker)
+        self.assertEqual(
+            orchestrator.attack_all.call_args_list,
+            [call(first_selected), call(second_selected)],
+        )
+
+        self.assertEqual(scanner_cls.call_count, 3)
+        for scanner_call in scanner_cls.call_args_list:
+            self.assertIs(scanner_call.args[0], cfg)
+            self.assertIs(scanner_call.args[1], store)
+            self.assertIs(scanner_call.args[2], tracker)
+
+        first_scanner.scan.assert_called_once_with()
+        second_scanner.scan.assert_called_once_with()
+        first_scanner.select_targets.assert_called_once_with([first_target])
+        second_scanner.select_targets.assert_called_once_with([second_target])
+        process_pool.return_value.cleanup_all.assert_called_once_with()
+        airmon_stop.assert_not_called()
+
+
+if __name__ == "__main__":
+    unittest.main()
