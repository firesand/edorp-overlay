+"""Regression tests for wireless-interface recovery after driver reprobes.
+
+These tests deliberately mock every process and radio-facing API.  They must be
+safe to run on machines with no wireless interface and must never change the
+state of a real adapter.
+"""
+
+from __future__ import annotations
+
+import unittest
+from unittest.mock import patch
+
+from wiflux.tools.airmon import Airmon
+from wiflux.tools.interface import (
+    InterfaceRecoveryError,
+    recover_interface,
+    set_channel,
+)
+
+
+PCI_DEVICE = "/sys/devices/pci0000:00/0000:09:00.0"
+
+
+class InterfaceRecoveryTestCase(unittest.TestCase):
+    def setUp(self) -> None:
+        self._base_interface = Airmon.base_interface
+        self._base_device_path = Airmon.base_device_path
+
+    def tearDown(self) -> None:
+        Airmon.base_interface = self._base_interface
+        Airmon.base_device_path = self._base_device_path
+
+    @staticmethod
+    def _device_path(name: str) -> str | None:
+        if name in {"wlp9s0", "wlp9s0mon"}:
+            return PCI_DEVICE
+        if name == "wlan1":
+            return "/sys/devices/pci0000:00/0000:0a:00.0"
+        return None
+
+    def test_iw_dev_parser_assigns_phy_header_to_each_interface(self) -> None:
+        iw_output = """\
+phy#2
+\tInterface wlp9s0
+\t\tifindex 7
+\t\twdev 0x200000001
+\t\ttype managed
+phy#7
+\tInterface wlan1mon
+\t\tifindex 12
+\t\twdev 0x700000001
+\t\ttype monitor
+"""
+
+        with patch(
+            "wiflux.tools.airmon.run",
+            return_value=(iw_output, "", 0),
+        ) as run_mock:
+            interfaces = Airmon.list_interfaces()
+
+        self.assertEqual(
+            interfaces,
+            [
+                {"name": "wlp9s0", "type": "managed", "phy": "2"},
+                {"name": "wlan1mon", "type": "monitor", "phy": "7"},
+            ],
+        )
+        run_mock.assert_called_once_with(["iw", "dev"])
+
+    def test_reprobe_selects_managed_interface_on_same_device(self) -> None:
+        """A phy/name reset must not make recovery jump to another radio."""
+        Airmon.base_interface = "wlp9s0"
+        Airmon.base_device_path = PCI_DEVICE
+        interfaces = [
+            {"name": "wlan1", "type": "monitor", "phy": "7"},
+            {"name": "wlp9s0", "type": "managed", "phy": "2"},
+        ]
+        monitor_started = False
+
+        def is_monitor(name: str) -> bool:
+            return monitor_started and name == "wlp9s0mon"
+
+        def start(name: str, *, kill_conflicts: bool = False) -> str:
+            nonlocal monitor_started
+            self.assertEqual(name, "wlp9s0")
+            self.assertFalse(kill_conflicts)
+            monitor_started = True
+            return "wlp9s0mon"
+
+        with (
+            patch("wiflux.tools.interface.ProcessPool") as pool,
+            patch("wiflux.tools.interface.run", return_value=("", "", 0)),
+            patch("wiflux.tools.interface.time.sleep"),
+            patch.object(Airmon, "list_interfaces", return_value=interfaces),
+            patch.object(Airmon, "device_path", side_effect=self._device_path),
+            patch.object(Airmon, "is_monitor", side_effect=is_monitor),
+            patch.object(Airmon, "start", side_effect=start) as start_mock,
+        ):
+            recovered = recover_interface(
+                "wlp9s0mon",
+                channel=1,
+                band="2",
+                wait_timeout=0,
+            )
+
+        self.assertEqual(recovered, "wlp9s0mon")
+        start_mock.assert_called_once_with("wlp9s0", kill_conflicts=False)
+        pool.return_value.cleanup_all.assert_called_once_with()
+
+    def test_reprobe_falls_back_to_exact_monitor_name_stem(self) -> None:
+        """Predictable ``foo``/``foomon`` renames work without cached sysfs data."""
+        Airmon.base_interface = None
+        Airmon.base_device_path = None
+        interfaces = [{"name": "wlp9s0", "type": "managed", "phy": "2"}]
+        monitor_started = False
+
+        def is_monitor(name: str) -> bool:
+            return monitor_started and name == "wlp9s0mon"
+
+        def start(name: str, *, kill_conflicts: bool = False) -> str:
+            nonlocal monitor_started
+            monitor_started = True
+            return f"{name}mon"
+
+        with (
+            patch("wiflux.tools.interface.ProcessPool"),
+            patch("wiflux.tools.interface.run", return_value=("", "", 0)),
+            patch("wiflux.tools.interface.time.sleep"),
+            patch.object(Airmon, "list_interfaces", return_value=interfaces),
+            patch.object(Airmon, "device_path", return_value=None),
+            patch.object(Airmon, "is_monitor", side_effect=is_monitor),
+            patch.object(Airmon, "start", side_effect=start) as start_mock,
+        ):
+            recovered = recover_interface("wlp9s0mon", wait_timeout=0)
+
+        self.assertEqual(recovered, "wlp9s0mon")
+        start_mock.assert_called_once_with("wlp9s0", kill_conflicts=False)
+
+    def test_ambiguous_radios_raise_instead_of_selecting_first(self) -> None:
+        Airmon.base_interface = None
+        Airmon.base_device_path = None
+        interfaces = [
+            {"name": "wlan0", "type": "managed", "phy": "0"},
+            {"name": "wlan1", "type": "monitor", "phy": "1"},
+        ]
+
+        with (
+            patch("wiflux.tools.interface.ProcessPool"),
+            patch("wiflux.tools.interface.run", return_value=("", "", 0)),
+            patch("wiflux.tools.interface.time.sleep"),
+            patch.object(Airmon, "list_interfaces", return_value=interfaces),
+            patch.object(Airmon, "device_path", return_value=None),
+            patch.object(Airmon, "is_monitor", return_value=False),
+            patch.object(Airmon, "start") as start_mock,
+        ):
+            with self.assertRaisesRegex(
+                InterfaceRecoveryError,
+                "(?i)ambiguous|multiple|reprobe|available",
+            ):
+                recover_interface("missing0mon", wait_timeout=0)
+
+        start_mock.assert_not_called()
+
+    def test_known_device_does_not_fall_back_to_unrelated_single_radio(self) -> None:
+        Airmon.base_interface = "wlp9s0"
+        Airmon.base_device_path = PCI_DEVICE
+        interfaces = [{"name": "wlan1", "type": "monitor", "phy": "7"}]
+
+        with (
+            patch("wiflux.tools.interface.ProcessPool"),
+            patch("wiflux.tools.interface.run", return_value=("", "", 0)),
+            patch("wiflux.tools.interface.time.sleep"),
+            patch.object(Airmon, "list_interfaces", return_value=interfaces),
+            patch.object(Airmon, "device_path", side_effect=self._device_path),
+            patch.object(Airmon, "is_monitor", return_value=False),
+            patch.object(Airmon, "start") as start_mock,
+        ):
+            with self.assertRaises(InterfaceRecoveryError):
+                recover_interface("wlp9s0mon", wait_timeout=0)
+
+        start_mock.assert_not_called()
+
+    def test_strict_channel_failure_raises(self) -> None:
+        commands = [["iw", "dev", "wlan0mon", "set", "channel", "6"]]
+        with (
+            patch("wiflux.tools.radio.set_channel_cmd", return_value=commands),
+            patch("wiflux.tools.interface.run", return_value=("", "device busy", 1)) as run_mock,
+        ):
+            with self.assertRaisesRegex(InterfaceRecoveryError, "(?i)channel|tune"):
+                set_channel("wlan0mon", 6, band="2", strict=True)
+
+        run_mock.assert_called_once_with(commands[0], timeout=5)
+
+    def test_kill_conflicts_is_forwarded_when_monitor_mode_is_recreated(self) -> None:
+        Airmon.base_interface = "wlp9s0"
+        Airmon.base_device_path = PCI_DEVICE
+        interfaces = [{"name": "wlp9s0", "type": "managed", "phy": "2"}]
+        monitor_started = False
+
+        def is_monitor(name: str) -> bool:
+            return monitor_started and name == "wlp9s0mon"
+
+        def start(name: str, *, kill_conflicts: bool = False) -> str:
+            nonlocal monitor_started
+            monitor_started = True
+            return "wlp9s0mon"
+
+        def failed_direct_mode_switch(cmd, *, timeout=60, shell=False):
+            if cmd[:2] == ["iw", "dev"]:
+                return "", "device busy", 1
+            return "", "", 0
+
+        with (
+            patch("wiflux.tools.interface.ProcessPool"),
+            patch("wiflux.tools.interface.run", side_effect=failed_direct_mode_switch),
+            patch("wiflux.tools.interface.time.sleep"),
+            patch.object(Airmon, "list_interfaces", return_value=interfaces),
+            patch.object(Airmon, "device_path", side_effect=self._device_path),
+            patch.object(Airmon, "is_monitor", side_effect=is_monitor),
+            patch.object(Airmon, "start", side_effect=start) as start_mock,
+        ):
+            recovered = recover_interface(
+                "wlp9s0mon",
+                kill_conflicts=True,
+                wait_timeout=0,
+            )
+
+        self.assertEqual(recovered, "wlp9s0mon")
+        start_mock.assert_called_once_with("wlp9s0", kill_conflicts=True)
+
+
+if __name__ == "__main__":
+    unittest.main()
