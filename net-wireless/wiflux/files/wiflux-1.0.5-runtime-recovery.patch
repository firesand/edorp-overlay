+#!/usr/bin/env python3
+"""Regression tests for fatal WPS helper failures.
+
+These tests never invoke a wireless tool or touch a network interface.  All
+external process and interface operations are mocked.
+"""
+
+from __future__ import annotations
+
+import io
+import signal
+import tempfile
+import unittest
+from unittest.mock import MagicMock, patch
+
+from rich.console import Console
+
+from wiflux.attacks.base import AttackResult
+from wiflux.attacks.handshake import HandshakeAttack
+from wiflux.attacks.wps import WPSPinAttack, WPSPixieAttack
+from wiflux.config import WifluxConfig
+from wiflux.models import AccessPoint, EncryptionType, WPSState
+from wiflux.orchestrator import Orchestrator
+from wiflux.process import RUN_TIMEOUT, ExternalToolCrash
+from wiflux.progress import ProgressTracker
+from wiflux.results import ResultStore
+from wiflux.tools.reaver import WPSAttack
+from wiflux.tools.wash import Wash
+
+
+def _wps_ap() -> AccessPoint:
+    ap = AccessPoint(
+        bssid="A4:2A:95:2F:95:09",
+        channel=1,
+        encryption=EncryptionType.WPA2,
+        auth="PSK",
+        power=70,
+        essid="Authorized-Lab",
+        essid_known=True,
+    )
+    ap.wps = WPSState.UNLOCKED
+    return ap
+
+
+class TestReaverCrashHandling(unittest.TestCase):
+    def test_stream_cmd_raises_and_logs_sigsegv(self):
+        """A naturally signalled child must not look like an ordinary miss."""
+        proc = MagicMock()
+        proc.poll.return_value = -signal.SIGSEGV
+        proc.wait.return_value = -signal.SIGSEGV
+        proc.returncode = -signal.SIGSEGV
+        proc.stdout = MagicMock()
+        lines: list[str] = []
+
+        with patch("wiflux.tools.reaver.subprocess.Popen", return_value=proc):
+            with self.assertRaises(ExternalToolCrash) as caught:
+                WPSAttack._stream_cmd(
+                    ["reaver", "-i", "wlan0mon"],
+                    timeout=30,
+                    on_line=lines.append,
+                    should_stop=None,
+                    pixie=True,
+                )
+
+        self.assertEqual(caught.exception.tool, "reaver")
+        self.assertEqual(caught.exception.returncode, -signal.SIGSEGV)
+        self.assertIn("SIGSEGV", str(caught.exception))
+        self.assertTrue(any("SIGSEGV" in line for line in lines))
+
+    def test_algorithmic_pin_loop_stops_after_first_backend_crash(self):
+        cfg = WifluxConfig()
+        cfg.scan.interface = "wlan0mon"
+        pins = ["12345670", "00000000", "11111111"]
+        crash = ExternalToolCrash("reaver", -signal.SIGSEGV)
+
+        with (
+            patch(
+                "wiflux.tools.reaver.algorithmic_wps_pins",
+                return_value=pins,
+            ),
+            patch(
+                "wiflux.tools.reaver.recover_interface",
+                return_value="wlan0mon",
+            ),
+            patch.object(WPSAttack, "_stream_cmd", side_effect=crash) as stream,
+        ):
+            with self.assertRaises(ExternalToolCrash):
+                WPSAttack._try_algorithmic_pins(
+                    cfg,
+                    _wps_ap(),
+                    timeout=90,
+                )
+
+        self.assertEqual(stream.call_count, 1)
+        first_cmd = stream.call_args.args[0]
+        self.assertEqual(first_cmd[first_cmd.index("-p") + 1], pins[0])
+
+    def test_pin_deadline_is_recalculated_after_interface_recovery(self):
+        cfg = WifluxConfig()
+        cfg.scan.interface = "wlan0mon"
+        cfg.attack.algorithmic_wps = False
+
+        # t=100 establishes the deadline, t=101 computes the pre-recovery
+        # budget, and t=106 represents five seconds spent recovering the radio.
+        with (
+            patch(
+                "wiflux.tools.reaver.time.monotonic",
+                side_effect=[100.0, 101.0, 106.0],
+            ),
+            patch("wiflux.tools.reaver.which", return_value=True),
+            patch(
+                "wiflux.tools.reaver.recover_interface",
+                return_value="wlan0mon",
+            ),
+            patch.object(
+                WPSAttack,
+                "_stream_cmd",
+                return_value=(None, None),
+            ) as stream,
+        ):
+            WPSAttack.run_pin(cfg, _wps_ap(), timeout=10)
+
+        stream.assert_called_once()
+        self.assertEqual(stream.call_args.args[1], 4)
+
